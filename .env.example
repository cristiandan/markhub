# Markhub Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# For local development, use a local Postgres instance:
# DATABASE_URL="postgresql://user:password@localhost:5432/markhub?schema=public"
#
# For Render, use the Internal Database URL from your Postgres dashboard:
# DATABASE_URL="postgresql://user:password@dpg-xxx.render.com/markhub"
DATABASE_URL=

# =============================================================================
# NextAuth.js / Auth.js v5
# =============================================================================
# Generate a secret: openssl rand -base64 32
# AUTH_SECRET is the v5 name (NEXTAUTH_SECRET also works for compatibility)
AUTH_SECRET=
# Base URL (http://localhost:3000 for dev, https://markhub.md for prod)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# GitHub OAuth
# =============================================================================
# Create an OAuth app at: https://github.com/settings/developers
# Callback URL: https://your-domain/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
