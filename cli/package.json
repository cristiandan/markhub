{
  "name": "markhub",
  "version": "0.1.0",
  "description": "CLI for Markhub - share and discover agent markdown files",
  "author": "Markhub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cristiandan/markhub.git",
    "directory": "cli"
  },
  "homepage": "https://markhub.md",
  "keywords": [
    "markhub",
    "markdown",
    "cli",
    "agents",
    "ai"
  ],
  "type": "module",
  "bin": {
    "markhub": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "open": "^10.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
